# AikoAi Dotfiles Environment Variables
# Copy this file to .env and configure it for your machine.

# Monitor configuration (used by Hyprland)
MAIN_MONITOR=eDP-1
SECOND_MONITOR=HDMI-A-1

# Network interface for waybar
WIFI_INTERFACE=wlan0
ETH_INTERFACE=eth0

# Default applications
TERMINAL=kitty
BROWSER=firefox
FILE_MANAGER=yazi
